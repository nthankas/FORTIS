# FORTIS stack CLI environment template.
#
# Copy this file to .env and edit values for the current machine:
#
#   cp .env.example .env
#
# The real .env is gitignored. Every machine that runs ./stack needs one.
# The stack script loads .env via `set -a; source .env; set +a` so every
# value here becomes an environment variable for docker compose.

# ---------------------------------------------------------------------------
# Git ref the stack runs on this machine. `./stack pull` checks this out;
# `./stack up` warns if HEAD is something else. Use a branch name for dev
# machines and a tagged release for production / demo machines.
# ---------------------------------------------------------------------------
FORTIS_REF=main

# ---------------------------------------------------------------------------
# Compose profile selector.
#   cpu -> docker/docker-compose.yml only (service: dev, container: fortis-dev)
#   gpu -> cpu base + docker/docker-compose.gpu.yml overlay
#          (adds service / container fortis-dev-gpu, requires NVIDIA toolkit)
#
# Use `cpu` for any machine without an NVIDIA GPU. Use `gpu` on the FORTIS
# PC (RTX 4080), the IdeaPad (RTX 5050 Laptop), and the Jetson Orin Nano.
# ---------------------------------------------------------------------------
COMPOSE_PROFILE=cpu

# ---------------------------------------------------------------------------
# ROS 2 DDS domain id. All FORTIS machines on the same physical network MUST
# agree on this number, otherwise their nodes will not see each other. The
# project convention is 42; do not change this casually.
# ---------------------------------------------------------------------------
ROS_DOMAIN_ID=42

# ---------------------------------------------------------------------------
# docker compose project name. Determines container / network / volume name
# prefixes. Leave at the default unless you are running two FORTIS stacks
# side by side on one host (rare).
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=fortis

# ---------------------------------------------------------------------------
# Optional: hostname / IP of the Jetson, for `./stack ssh` from a dev desk.
# Accepts anything ssh accepts: bare IP, hostname, user@host, or an alias
# defined in ~/.ssh/config. Leave blank on the Jetson itself; ./stack ssh
# is a no-op when the local machine matches this host.
#
# Examples:
#   FORTIS_JETSON_HOST=fortis@10.0.0.194
#   FORTIS_JETSON_HOST=100.93.172.109     # Tailscale persistent IP
#   FORTIS_JETSON_HOST=jetson             # ~/.ssh/config alias
# ---------------------------------------------------------------------------
FORTIS_JETSON_HOST=

# ---------------------------------------------------------------------------
# Optional: NGC API key for `docker login nvcr.io`, only needed if the GPU
# container's Isaac ROS base image needs to be pulled from nvcr.io. Leave
# blank to run `docker login nvcr.io` manually instead. Never commit a real
# key here; .env is gitignored.
# ---------------------------------------------------------------------------
NGC_API_KEY=
