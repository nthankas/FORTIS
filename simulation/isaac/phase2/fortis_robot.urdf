<?xml version="1.0" encoding="UTF-8"?>
<!--
  FORTIS Tokamak Inspection Robot URDF

  All dimensions in reactor world units (inches * 0.024).
  Masses in kg (real). This matches the reactor.usd coordinate system.

  Coordinate convention: X = forward (radially outward), Y = left, Z = up

  Kinematic tree:
    chassis_link
      ├── fl_wheel (continuous, Y) → fl_wheel_link
      ├── fr_wheel (continuous, Y) → fr_wheel_link
      ├── rl_wheel (continuous, Y) → rl_wheel_link
      ├── rr_wheel (continuous, Y) → rr_wheel_link
      └── j1_yaw (revolute, Z) → j1_link
           └── j2_shoulder (revolute, Y) → j2_link
                └── j3_elbow (revolute, Y) → j3_link
                     └── j4_wrist (revolute, Y) → j4_link

  Chassis: 14" x 13" x 9" (0.336 x 0.312 x 0.216), 18.14 kg
  Wheels: 3" radius, 2" wide (0.072 r, 0.048 w), 1.134 kg each
  Arm: L1=16" L2=22" L3=8" (0.384, 0.528, 0.192), ~0.567 kg per link
-->
<robot name="fortis_robot">

  <!-- ===== CHASSIS ===== -->
  <link name="chassis_link">
    <visual>
      <geometry>
        <box size="0.336 0.312 0.216"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.336 0.312 0.216"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="18.14"/>
      <inertia ixx="0.2177" ixy="0" ixz="0"
               iyy="0.2413" iyz="0"
               izz="0.3179"/>
    </inertial>
  </link>

  <!-- ===== FRONT-LEFT WHEEL ===== -->
  <joint name="fl_wheel" type="continuous">
    <parent link="chassis_link"/>
    <child link="fl_wheel_link"/>
    <origin xyz="0.168 0.156 -0.108" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="fl_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
      <material name="rubber_black">
        <color rgba="0.15 0.15 0.15 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.134"/>
      <inertia ixx="0.001688" ixy="0" ixz="0"
               iyy="0.002939" iyz="0"
               izz="0.001688"/>
    </inertial>
  </link>

  <!-- ===== FRONT-RIGHT WHEEL ===== -->
  <joint name="fr_wheel" type="continuous">
    <parent link="chassis_link"/>
    <child link="fr_wheel_link"/>
    <origin xyz="0.168 -0.156 -0.108" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="fr_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
      <material name="rubber_black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.134"/>
      <inertia ixx="0.001688" ixy="0" ixz="0"
               iyy="0.002939" iyz="0"
               izz="0.001688"/>
    </inertial>
  </link>

  <!-- ===== REAR-LEFT WHEEL ===== -->
  <joint name="rl_wheel" type="continuous">
    <parent link="chassis_link"/>
    <child link="rl_wheel_link"/>
    <origin xyz="-0.168 0.156 -0.108" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="rl_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
      <material name="rubber_black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.134"/>
      <inertia ixx="0.001688" ixy="0" ixz="0"
               iyy="0.002939" iyz="0"
               izz="0.001688"/>
    </inertial>
  </link>

  <!-- ===== REAR-RIGHT WHEEL ===== -->
  <joint name="rr_wheel" type="continuous">
    <parent link="chassis_link"/>
    <child link="rr_wheel_link"/>
    <origin xyz="-0.168 -0.156 -0.108" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="rr_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
      <material name="rubber_black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.072" length="0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.134"/>
      <inertia ixx="0.001688" ixy="0" ixz="0"
               iyy="0.002939" iyz="0"
               izz="0.001688"/>
    </inertial>
  </link>

  <!-- ===== ARM J1: BASE YAW ===== -->
  <!-- Sits on top of chassis center. Rotates around Z (yaw). -->
  <joint name="j1_yaw" type="revolute">
    <parent link="chassis_link"/>
    <child link="j1_link"/>
    <origin xyz="0 0 0.132" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="20" velocity="3.14"/>
  </joint>
  <link name="j1_link">
    <visual>
      <geometry>
        <box size="0.048 0.048 0.048"/>
      </geometry>
      <material name="arm_gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.048 0.048 0.048"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.567"/>
      <inertia ixx="0.000218" ixy="0" ixz="0"
               iyy="0.000218" iyz="0"
               izz="0.000218"/>
    </inertial>
  </link>

  <!-- ===== ARM J2: SHOULDER PITCH ===== -->
  <!-- At top of J1 cube. Rotates around Y (pitch). Link extends upward L1=0.384. -->
  <joint name="j2_shoulder" type="revolute">
    <parent link="j1_link"/>
    <child link="j2_link"/>
    <origin xyz="0 0 0.024" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="2.3562" effort="20" velocity="2.0"/>
  </joint>
  <link name="j2_link">
    <visual>
      <origin xyz="0 0 0.192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.384"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.192" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.384"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.192"/>
      <mass value="0.567"/>
      <inertia ixx="0.007049" ixy="0" ixz="0"
               iyy="0.007049" iyz="0"
               izz="0.000163"/>
    </inertial>
  </link>

  <!-- ===== ARM J3: ELBOW PITCH ===== -->
  <!-- L1 above J2 frame. Rotates around Y. Link extends upward L2=0.528. -->
  <joint name="j3_elbow" type="revolute">
    <parent link="j2_link"/>
    <child link="j3_link"/>
    <origin xyz="0 0 0.384" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6180" upper="2.6180" effort="15" velocity="2.0"/>
  </joint>
  <link name="j3_link">
    <visual>
      <origin xyz="0 0 0.264" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.528"/>
      </geometry>
      <material name="arm_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.264" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.528"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.264"/>
      <mass value="0.567"/>
      <inertia ixx="0.013219" ixy="0" ixz="0"
               iyy="0.013219" iyz="0"
               izz="0.0000919"/>
    </inertial>
  </link>

  <!-- ===== ARM J4: WRIST PITCH ===== -->
  <!-- L2 above J3 frame. Rotates around Y. Link extends upward L3=0.192. -->
  <joint name="j4_wrist" type="revolute">
    <parent link="j3_link"/>
    <child link="j4_link"/>
    <origin xyz="0 0 0.528" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="10" velocity="3.0"/>
  </joint>
  <link name="j4_link">
    <visual>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.192"/>
      </geometry>
      <material name="arm_light">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="0.192"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.096"/>
      <mass value="0.284"/>
      <inertia ixx="0.000883" ixy="0" ixz="0"
               iyy="0.000883" iyz="0"
               izz="0.0000205"/>
    </inertial>
  </link>

</robot>
