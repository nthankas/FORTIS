#!/usr/bin/env bash
# =============================================================================
# stack - FORTIS deployment helper.
#
# A thin wrapper around `git` and `docker compose` so common deployment
# workflows are one-line operations. Reads configuration from a .env file in
# the repository root (template: .env.example).
#
# Usage:
#     ./stack <command> [args...]
#
# Run `./stack help` for the full command reference, or `./stack help <cmd>`
# for help on one subcommand.
#
# This script intentionally has no Python or npm dependencies; everything it
# does is achievable manually with `git` and `docker compose`. See
# tools/stack/README.md for the underlying commands each subcommand wraps.
# =============================================================================

set -euo pipefail

# -----------------------------------------------------------------------------
# Paths and constants
# -----------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}"
ENV_FILE="${REPO_ROOT}/.env"
ENV_EXAMPLE="${REPO_ROOT}/.env.example"
COMPOSE_BASE="${REPO_ROOT}/docker/docker-compose.yml"
COMPOSE_GPU="${REPO_ROOT}/docker/docker-compose.gpu.yml"

# -----------------------------------------------------------------------------
# Color output helpers. Suppressed when stdout is not a TTY, when NO_COLOR is
# set (https://no-color.org), or when running under a dumb terminal.
# -----------------------------------------------------------------------------
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]] && [[ "${TERM:-dumb}" != "dumb" ]]; then
    C_RESET=$'\033[0m'
    C_INFO=$'\033[1;34m'
    C_WARN=$'\033[1;33m'
    C_ERR=$'\033[1;31m'
    C_OK=$'\033[1;32m'
else
    C_RESET=""
    C_INFO=""
    C_WARN=""
    C_ERR=""
    C_OK=""
fi

info()  { printf '%s[stack]%s %s\n' "${C_INFO}" "${C_RESET}" "$*" >&2; }
warn()  { printf '%s[stack]%s %s\n' "${C_WARN}" "${C_RESET}" "$*" >&2; }
err()   { printf '%s[stack]%s %s\n' "${C_ERR}"  "${C_RESET}" "$*" >&2; }
ok()    { printf '%s[stack]%s %s\n' "${C_OK}"   "${C_RESET}" "$*" >&2; }

die() {
    err "$@"
    exit 1
}

# -----------------------------------------------------------------------------
# .env loader. Sourced under `set -a` so every KEY=VALUE becomes exported.
# Defaults are applied AFTER sourcing so unset keys still have sensible values.
# -----------------------------------------------------------------------------
load_env() {
    if [[ -f "${ENV_FILE}" ]]; then
        # shellcheck disable=SC1090
        set -a
        # shellcheck source=/dev/null
        source "${ENV_FILE}"
        set +a
        ENV_LOADED=1
    else
        ENV_LOADED=0
    fi

    : "${FORTIS_REF:=main}"
    : "${COMPOSE_PROFILE:=cpu}"
    : "${ROS_DOMAIN_ID:=42}"
    : "${COMPOSE_PROJECT_NAME:=fortis}"
    : "${FORTIS_JETSON_HOST:=}"
    : "${NGC_API_KEY:=}"

    export FORTIS_REF COMPOSE_PROFILE ROS_DOMAIN_ID COMPOSE_PROJECT_NAME
    export FORTIS_JETSON_HOST NGC_API_KEY
}

require_env_file() {
    if [[ "${ENV_LOADED:-0}" -ne 1 ]]; then
        err "No .env file at ${ENV_FILE}"
        err "Copy the template and edit values for this machine:"
        err "    cp .env.example .env"
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# Profile -> compose file args + container name.
# -----------------------------------------------------------------------------
compose_files() {
    case "${COMPOSE_PROFILE}" in
        cpu)
            printf -- '-f\n%s\n' "${COMPOSE_BASE}"
            ;;
        gpu)
            printf -- '-f\n%s\n-f\n%s\n' "${COMPOSE_BASE}" "${COMPOSE_GPU}"
            ;;
        *)
            die "Unknown COMPOSE_PROFILE=${COMPOSE_PROFILE} (expected cpu or gpu)"
            ;;
    esac
}

# Default service / container per profile.
#   cpu profile: docker-compose.yml service `dev` -> container `fortis-dev`
#   gpu profile: docker-compose.gpu.yml service / container `fortis-dev-gpu`
default_service() {
    case "${COMPOSE_PROFILE}" in
        cpu) printf 'dev' ;;
        gpu) printf 'fortis-dev-gpu' ;;
        *)   die "Unknown COMPOSE_PROFILE=${COMPOSE_PROFILE}" ;;
    esac
}

default_container() {
    case "${COMPOSE_PROFILE}" in
        cpu) printf 'fortis-dev' ;;
        gpu) printf 'fortis-dev-gpu' ;;
        *)   die "Unknown COMPOSE_PROFILE=${COMPOSE_PROFILE}" ;;
    esac
}

# Wrapper around `docker compose` that injects -f for every active compose
# file. Reads files from compose_files() (newline-separated).
dc() {
    local -a files=()
    local line
    while IFS= read -r line; do
        [[ -n "${line}" ]] && files+=("${line}")
    done < <(compose_files)
    docker compose "${files[@]}" "$@"
}

# -----------------------------------------------------------------------------
# Git helpers.
# -----------------------------------------------------------------------------
git_in_repo() {
    git -C "${REPO_ROOT}" "$@"
}

git_dirty() {
    # Returns 0 if the working tree has uncommitted changes, 1 otherwise.
    if [[ -n "$(git_in_repo status --porcelain 2>/dev/null || true)" ]]; then
        return 0
    fi
    return 1
}

git_head_ref() {
    # Symbolic ref for HEAD (branch name), or short SHA when detached.
    local ref
    if ref="$(git_in_repo symbolic-ref --short -q HEAD 2>/dev/null)"; then
        printf '%s' "${ref}"
    else
        git_in_repo rev-parse --short HEAD 2>/dev/null || printf 'unknown'
    fi
}

confirm() {
    # Prompt for yes/no confirmation. Returns 0 on yes, 1 on no.
    # Bypassed entirely if STACK_ASSUME_YES=1 or --yes was passed earlier.
    if [[ "${STACK_ASSUME_YES:-0}" == "1" ]]; then
        return 0
    fi
    local prompt="${1:-Continue?} [y/N]: "
    local reply
    if ! read -r -p "${prompt}" reply; then
        return 1
    fi
    case "${reply}" in
        y|Y|yes|YES) return 0 ;;
        *) return 1 ;;
    esac
}

# -----------------------------------------------------------------------------
# Help text.
# -----------------------------------------------------------------------------
help_main() {
    cat <<'EOF'
stack - FORTIS deployment helper.

USAGE
    ./stack <command> [args...]

COMMANDS
    up                    Bring the stack up (docker compose up -d).
    down                  Stop and remove containers (docker compose down).
    pull                  git fetch + checkout to FORTIS_REF.
    restart [service]     Restart one or all services.
    rebuild [service]     Rebuild image for one or all services.
    logs [service] [-f]   Tail logs for one or all services.
    exec [service]        Open a bash shell inside the running container.
    status                Print git ref, profile, container status.
    switch <ref>          Set FORTIS_REF, pull, restart.
    ssh                   SSH to FORTIS_JETSON_HOST (dev desk -> Jetson).
    help [command]        Print this help, or help for one command.

ENVIRONMENT
    Reads .env in the repo root. Copy from .env.example on first run:
        cp .env.example .env

    Required keys: FORTIS_REF, COMPOSE_PROFILE, ROS_DOMAIN_ID,
                   COMPOSE_PROJECT_NAME.
    Optional keys: FORTIS_JETSON_HOST, NGC_API_KEY.

EXAMPLES
    ./stack up                       # bring everything up
    ./stack exec                     # shell into the default dev container
    ./stack logs --follow            # tail every container's logs
    ./stack switch feat/foo          # checkout feat/foo and restart
    ./stack status                   # show what's running

See tools/stack/README.md for the full reference.
EOF
}

help_up() {
    cat <<'EOF'
./stack up

Bring the FORTIS stack up. Equivalent to `docker compose -f ... up -d` for
the active profile (cpu = docker-compose.yml only; gpu adds the gpu overlay).

Before starting containers, the command:
  1. Loads .env from the repo root.
  2. Warns if HEAD does not match FORTIS_REF (does NOT auto-checkout).
  3. Warns if the working tree is dirty.

If containers are already running this is effectively a no-op; docker compose
will start any missing ones and leave the rest untouched.

Options:
    --yes, -y     Skip all confirmation prompts.
    -h, --help    Print this help.
EOF
}

help_down() {
    cat <<'EOF'
./stack down

Stop and remove the FORTIS stack containers (docker compose down). Volumes
are preserved; only the containers are torn down. This is a destructive op
(running containers exit), so it prompts for confirmation unless --yes.

Options:
    --yes, -y     Skip confirmation.
    -h, --help    Print this help.
EOF
}

help_pull() {
    cat <<'EOF'
./stack pull

Update the workspace to the configured FORTIS_REF:
    git fetch --all --prune
    git checkout <FORTIS_REF>
    git pull --ff-only       (only for branch refs)

Refuses to run if the working tree is dirty. Pass --force to attempt the
checkout anyway (git itself will still refuse to overwrite local changes).

Options:
    --force, -f   Attempt checkout even on dirty tree.
    -h, --help    Print this help.
EOF
}

help_restart() {
    cat <<'EOF'
./stack restart [service]

Restart one or every service in the active compose profile. With no service
argument, every service is restarted.

Options:
    -h, --help    Print this help.

Examples:
    ./stack restart                # restart all
    ./stack restart fortis-dev     # restart only the cpu dev container
EOF
}

help_rebuild() {
    cat <<'EOF'
./stack rebuild [service] [--no-cache]

Rebuild docker images for one or every service. With --no-cache, layer
cache is dropped (slow but guaranteed clean); --no-cache prompts for
confirmation unless --yes is also given.

Options:
    --no-cache    Drop docker layer cache.
    --yes, -y     Skip confirmation prompt for --no-cache.
    -h, --help    Print this help.
EOF
}

help_logs() {
    cat <<'EOF'
./stack logs [service] [--follow]

Show logs from one or every service. Without --follow the command prints
recent output and exits; with --follow it tails new output until Ctrl-C.

Options:
    --follow, -f   Stream new output.
    -h, --help     Print this help.
EOF
}

help_exec() {
    cat <<'EOF'
./stack exec [service]

Open an interactive bash shell inside the running container for the given
service. With no service argument, defaults to:
    cpu profile -> fortis-dev
    gpu profile -> fortis-dev-gpu

This wraps `docker exec -it <container> bash` against the container name
(not the service name), so the container must already be running. Use
`./stack up` first if needed.

Options:
    -h, --help    Print this help.
EOF
}

help_status() {
    cat <<'EOF'
./stack status

Print a compact summary of the local FORTIS stack:
  - Configured FORTIS_REF vs actual git HEAD (warns on mismatch).
  - Working tree clean / dirty.
  - Active compose profile (cpu or gpu).
  - ROS_DOMAIN_ID currently in use.
  - Containers running in the docker compose project, with image tags.

Safe to run with no .env present; warns and falls back to defaults.

Options:
    -h, --help    Print this help.
EOF
}

help_switch() {
    cat <<'EOF'
./stack switch <ref>

Set FORTIS_REF=<ref> in .env, then run `stack pull && stack restart`. Useful
on the Jetson for flipping between demo branches.

Refuses to run if the working tree is dirty unless --force is passed
through to the underlying `stack pull`.

Options:
    --force, -f   Forward to `stack pull --force`.
    -h, --help    Print this help.
EOF
}

help_ssh() {
    cat <<'EOF'
./stack ssh

SSH from the current machine to the Jetson, using FORTIS_JETSON_HOST from
.env. No-op (with a friendly message) when run on the Jetson itself, i.e.
when the local hostname / IP matches FORTIS_JETSON_HOST.

Any extra arguments are forwarded to ssh.

Options:
    -h, --help    Print this help.

Examples:
    ./stack ssh                       # interactive shell
    ./stack ssh "./stack status"      # one-shot remote command
EOF
}

help_for_command() {
    case "${1:-}" in
        up)       help_up ;;
        down)     help_down ;;
        pull)     help_pull ;;
        restart)  help_restart ;;
        rebuild)  help_rebuild ;;
        logs)     help_logs ;;
        exec)     help_exec ;;
        status)   help_status ;;
        switch)   help_switch ;;
        ssh)      help_ssh ;;
        help|"")  help_main ;;
        *)
            err "No help topic for: $1"
            help_main
            return 1
            ;;
    esac
}

# Handle `--help` / `-h` anywhere in a subcommand's argv. Returns 0 if help
# was printed (caller should exit), 1 otherwise.
handle_help_flag() {
    local cmd="$1"
    shift
    local arg
    for arg in "$@"; do
        case "${arg}" in
            -h|--help)
                help_for_command "${cmd}"
                return 0
                ;;
        esac
    done
    return 1
}

# Consume a `--yes` / `-y` anywhere in argv and set STACK_ASSUME_YES.
# Echoes the surviving args (NUL-separated would be safer but bash) on stdout.
consume_yes_flag() {
    local -a out=()
    local a
    for a in "$@"; do
        case "${a}" in
            -y|--yes) STACK_ASSUME_YES=1 ;;
            *) out+=("${a}") ;;
        esac
    done
    if [[ ${#out[@]} -gt 0 ]]; then
        printf '%s\n' "${out[@]}"
    fi
}

# -----------------------------------------------------------------------------
# Subcommands.
# -----------------------------------------------------------------------------
cmd_up() {
    if handle_help_flag up "$@"; then return 0; fi
    local -a rest=()
    if mapfile -t rest < <(consume_yes_flag "$@"); then :; fi
    require_env_file

    local head ref
    head="$(git_head_ref)"
    ref="${FORTIS_REF}"
    if [[ "${head}" != "${ref}" ]]; then
        warn "HEAD is '${head}' but FORTIS_REF=${ref}. Run './stack pull' to align."
    fi
    if git_dirty; then
        warn "Working tree is dirty. Containers will mount it as-is."
    fi

    info "Profile: ${COMPOSE_PROFILE} (ROS_DOMAIN_ID=${ROS_DOMAIN_ID}, project=${COMPOSE_PROJECT_NAME})"
    info "Bringing stack up..."
    dc up -d "${rest[@]+"${rest[@]}"}"
    ok "Stack is up. Run './stack status' for details."
}

cmd_down() {
    if handle_help_flag down "$@"; then return 0; fi
    local -a rest=()
    if mapfile -t rest < <(consume_yes_flag "$@"); then :; fi
    require_env_file

    if ! confirm "This will stop and remove the FORTIS stack containers. Continue?"; then
        info "Aborted."
        return 0
    fi

    info "Tearing down stack..."
    dc down "${rest[@]+"${rest[@]}"}"
    ok "Stack is down."
}

cmd_pull() {
    if handle_help_flag pull "$@"; then return 0; fi
    local force=0
    local arg
    for arg in "$@"; do
        case "${arg}" in
            -f|--force) force=1 ;;
            *) die "Unknown option to 'pull': ${arg}" ;;
        esac
    done
    require_env_file

    if git_dirty && [[ "${force}" -ne 1 ]]; then
        err "Working tree is dirty. Commit, stash, or pass --force to attempt anyway."
        git_in_repo status --short >&2 || true
        exit 1
    fi

    info "Fetching..."
    git_in_repo fetch --all --prune

    info "Checking out ${FORTIS_REF}..."
    git_in_repo checkout "${FORTIS_REF}"

    # Only fast-forward when the ref is currently a tracked branch.
    if git_in_repo symbolic-ref -q HEAD >/dev/null; then
        info "Fast-forwarding..."
        git_in_repo pull --ff-only || warn "Fast-forward failed; leaving HEAD where it is."
    else
        info "Detached HEAD at ${FORTIS_REF}; skipping pull."
    fi
    ok "On ${FORTIS_REF} ($(git_in_repo rev-parse --short HEAD))."
}

cmd_restart() {
    if handle_help_flag restart "$@"; then return 0; fi
    require_env_file

    local svc="${1:-}"
    if [[ -z "${svc}" ]]; then
        info "Restarting all services..."
        dc restart
    else
        info "Restarting service: ${svc}"
        dc restart "${svc}"
    fi
    ok "Done."
}

cmd_rebuild() {
    if handle_help_flag rebuild "$@"; then return 0; fi
    local no_cache=0
    local svc=""
    local -a rest=()
    if mapfile -t rest < <(consume_yes_flag "$@"); then :; fi

    local arg
    for arg in "${rest[@]+"${rest[@]}"}"; do
        case "${arg}" in
            --no-cache) no_cache=1 ;;
            -*) die "Unknown option to 'rebuild': ${arg}" ;;
            *)
                if [[ -z "${svc}" ]]; then
                    svc="${arg}"
                else
                    die "Multiple service names given to 'rebuild': ${svc}, ${arg}"
                fi
                ;;
        esac
    done
    require_env_file

    local -a build_args=()
    if [[ "${no_cache}" -eq 1 ]]; then
        if ! confirm "--no-cache drops the docker layer cache (slow). Continue?"; then
            info "Aborted."
            return 0
        fi
        build_args+=("--no-cache")
    fi

    if [[ -z "${svc}" ]]; then
        info "Rebuilding all services..."
        dc build "${build_args[@]+"${build_args[@]}"}"
    else
        info "Rebuilding service: ${svc}"
        dc build "${build_args[@]+"${build_args[@]}"}" "${svc}"
    fi
    ok "Build complete."
}

cmd_logs() {
    if handle_help_flag logs "$@"; then return 0; fi
    require_env_file

    local follow=0
    local svc=""
    local arg
    for arg in "$@"; do
        case "${arg}" in
            -f|--follow) follow=1 ;;
            -*) die "Unknown option to 'logs': ${arg}" ;;
            *)
                if [[ -z "${svc}" ]]; then
                    svc="${arg}"
                else
                    die "Multiple service names given to 'logs': ${svc}, ${arg}"
                fi
                ;;
        esac
    done

    local -a logs_args=()
    if [[ "${follow}" -eq 1 ]]; then
        logs_args+=("--follow")
    fi
    if [[ -n "${svc}" ]]; then
        dc logs "${logs_args[@]+"${logs_args[@]}"}" "${svc}"
    else
        dc logs "${logs_args[@]+"${logs_args[@]}"}"
    fi
}

cmd_exec() {
    if handle_help_flag exec "$@"; then return 0; fi
    require_env_file

    local container="${1:-}"
    if [[ -z "${container}" ]]; then
        container="$(default_container)"
    fi

    info "Opening shell in container '${container}'..."
    docker exec -it "${container}" bash
}

cmd_status() {
    if handle_help_flag status "$@"; then return 0; fi

    printf '%sFORTIS stack status%s\n' "${C_INFO}" "${C_RESET}"

    if [[ "${ENV_LOADED:-0}" -eq 1 ]]; then
        printf '  .env:               loaded (%s)\n' "${ENV_FILE}"
    else
        printf '  .env:               %sMISSING%s (falling back to defaults; copy .env.example to .env)\n' \
            "${C_WARN}" "${C_RESET}"
    fi

    local head dirty
    head="$(git_head_ref)"
    if git_dirty; then
        dirty="${C_WARN}dirty${C_RESET}"
    else
        dirty="${C_OK}clean${C_RESET}"
    fi
    printf '  FORTIS_REF (.env):  %s\n' "${FORTIS_REF}"
    printf '  git HEAD (actual):  %s\n' "${head}"
    if [[ "${head}" != "${FORTIS_REF}" ]]; then
        printf '  ref match:          %sMISMATCH%s  (run ./stack pull)\n' "${C_WARN}" "${C_RESET}"
    else
        printf '  ref match:          %sok%s\n' "${C_OK}" "${C_RESET}"
    fi
    printf '  working tree:       %b\n' "${dirty}"
    printf '  COMPOSE_PROFILE:    %s\n' "${COMPOSE_PROFILE}"
    printf '  ROS_DOMAIN_ID:      %s\n' "${ROS_DOMAIN_ID}"
    printf '  project name:       %s\n' "${COMPOSE_PROJECT_NAME}"

    printf '  containers:\n'
    if ! command -v docker >/dev/null 2>&1; then
        printf '    %sdocker not installed%s\n' "${C_WARN}" "${C_RESET}"
        return 0
    fi
    # `docker compose ps` against the active project. If compose can't find
    # the files we still want status to succeed, so swallow errors.
    local ps_out
    if ps_out="$(dc ps --format 'table {{.Service}}\t{{.Image}}\t{{.Status}}' 2>/dev/null)"; then
        if [[ -z "${ps_out}" ]] || [[ "$(printf '%s' "${ps_out}" | wc -l)" -le 1 ]]; then
            printf '    (none running)\n'
        else
            printf '%s\n' "${ps_out}" | sed 's/^/    /'
        fi
    else
        printf '    (docker compose unavailable or compose files not found)\n'
    fi
}

cmd_switch() {
    if handle_help_flag switch "$@"; then return 0; fi
    local force_flag=""
    local new_ref=""
    local arg
    for arg in "$@"; do
        case "${arg}" in
            -f|--force) force_flag="--force" ;;
            -*) die "Unknown option to 'switch': ${arg}" ;;
            *)
                if [[ -z "${new_ref}" ]]; then
                    new_ref="${arg}"
                else
                    die "switch takes exactly one <ref> argument"
                fi
                ;;
        esac
    done
    [[ -n "${new_ref}" ]] || die "Usage: ./stack switch <ref>"
    require_env_file

    info "Setting FORTIS_REF=${new_ref} in ${ENV_FILE}..."
    # Replace the FORTIS_REF= line in-place; append if not present.
    if grep -qE '^FORTIS_REF=' "${ENV_FILE}"; then
        # Portable sed in-place: write to temp then move.
        local tmp
        tmp="$(mktemp)"
        sed "s|^FORTIS_REF=.*|FORTIS_REF=${new_ref}|" "${ENV_FILE}" > "${tmp}"
        mv "${tmp}" "${ENV_FILE}"
    else
        printf '\nFORTIS_REF=%s\n' "${new_ref}" >> "${ENV_FILE}"
    fi
    # Reload so subsequent calls in the same process see the new value.
    load_env

    if [[ -n "${force_flag}" ]]; then
        cmd_pull "${force_flag}"
    else
        cmd_pull
    fi
    cmd_restart
}

cmd_ssh() {
    if handle_help_flag ssh "$@"; then return 0; fi
    require_env_file

    if [[ -z "${FORTIS_JETSON_HOST}" ]]; then
        die "FORTIS_JETSON_HOST is unset in .env (nothing to ssh to)."
    fi

    # If we're already on the host that matches FORTIS_JETSON_HOST, no-op.
    local local_host short
    local_host="$(hostname 2>/dev/null || printf 'unknown')"
    short="${FORTIS_JETSON_HOST##*@}"           # strip user@
    short="${short%%:*}"                        # strip :port
    if [[ "${local_host}" == "${short}" ]]; then
        info "Already on ${local_host}; ssh is a no-op here."
        return 0
    fi

    if ! command -v ssh >/dev/null 2>&1; then
        die "ssh binary not found in PATH."
    fi

    info "Connecting to ${FORTIS_JETSON_HOST}..."
    exec ssh "${FORTIS_JETSON_HOST}" "$@"
}

# -----------------------------------------------------------------------------
# Dispatcher.
# -----------------------------------------------------------------------------
main() {
    load_env

    local cmd="${1:-help}"
    if [[ $# -ge 1 ]]; then
        shift
    fi

    case "${cmd}" in
        up)       cmd_up "$@" ;;
        down)     cmd_down "$@" ;;
        pull)     cmd_pull "$@" ;;
        restart)  cmd_restart "$@" ;;
        rebuild)  cmd_rebuild "$@" ;;
        logs)     cmd_logs "$@" ;;
        exec)     cmd_exec "$@" ;;
        status)   cmd_status "$@" ;;
        switch)   cmd_switch "$@" ;;
        ssh)      cmd_ssh "$@" ;;
        help|-h|--help)
            help_for_command "${1:-}"
            ;;
        "")
            help_main
            ;;
        *)
            err "Unknown command: ${cmd}"
            err "Run './stack help' for usage."
            exit 2
            ;;
    esac
}

main "$@"
