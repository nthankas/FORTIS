<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fortis_arm">

  <!--
    FORTIS 4-DOF arm.
    Mount: arm_mount frame (provided by chassis).
    Chain: arm_mount -> arm_base -> link1 -> link2 -> link3 -> link4 -> ee
           with gripper on ee.

    Geometric convention:
      For each arm link, the link's frame origin sits on the proximal joint axis,
      with +X pointing toward the distal joint along the CF tube.
      Joint origins use axis-to-axis distance (the full kinematic span).
      The CF tube visual is centered between the two joints; the gap at each end
      represents the motor housing or gearbox flange.

    All four DOFs are revolute with explicit limits.
    The gripper is ONE driven prismatic joint with one passive mimic joint.
    Arm camera (OAK-D Pro AF) is a fixed link on link4 with a separate optical frame.
  -->

  <!-- =================== arm_base (J1 motor body) =================== -->
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="${arm_base_height}"/>
      </geometry>
      <material name="fortis_motor_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="${arm_base_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.40"
                            r="0.025"
                            h="${arm_base_height}"
                            xyz="0 0 ${arm_base_height/2}"/>
  </link>

  <joint name="arm_mount_to_arm_base" type="fixed">
    <parent link="arm_mount"/>
    <child  link="arm_base"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- =================== J1: yaw at base (revolute about Z) =================== -->
  <!--
    link1 represents the J2 motor mount bracket that rotates with J1.
    J2 axis sits j1_to_j2_axis (91 mm) above J1 axis.
    Mass of link1 is dominated by the NEMA 23 + 50:1 planetary at the J2 end.
  -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 ${j1_to_j2_axis/2}" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.060 ${j1_to_j2_axis}"/>
      </geometry>
      <material name="fortis_aluminum"/>
    </visual>
    <!-- J2 motor body (NEMA 23 + 50:1 planetary) sits at top of L1, axis along Y. -->
    <visual>
      <origin xyz="0 0 ${j1_to_j2_axis}" rpy="0 0 0"/>
      <geometry>
        <box size="${j2_motor_x} ${j2_motor_y} ${j2_motor_z}"/>
      </geometry>
      <material name="fortis_motor_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${j1_to_j2_axis/2}" rpy="0 0 0"/>
      <geometry>
        <box size="0.060 0.060 ${j1_to_j2_axis}"/>
      </geometry>
    </collision>
    <!-- CoM biased toward J2 end since the NEMA 23 + planetary sits there. -->
    <xacro:box_inertia m="${arm_link1_mass}"
                       x="0.060"
                       y="0.060"
                       z="${j1_to_j2_axis}"
                       xyz="0 0 ${j1_to_j2_axis*0.85}"/>
  </link>

  <joint name="joint_j1" type="revolute">
    <parent link="arm_base"/>
    <child  link="link1"/>
    <origin xyz="0 0 ${arm_base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${j1_lower}" upper="${j1_upper}"
           effort="${j1_effort}" velocity="${j_velocity}"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- =================== J2: shoulder pitch (revolute about Y) =================== -->
  <!--
    link2 frame origin is on the J2 rotation axis, +X toward J3.
    joint_j3 sits at xyz="(arm_link2_axis, 0, 0)" = true axis-to-axis distance.
    CF tube visual (arm_link2_tube) is centered in that span; the
    (arm_link2_axis - arm_link2_tube)/2 gap at each end is the motor housing.
  -->
  <link name="link2">
    <!-- Tube spans diagonally from L2 origin (J2 axis) to (arm_link2_axis, j2_offset_y, 0) (J3 axis).
         Yaw the box to align with that diagonal direction. -->
    <visual>
      <origin xyz="${arm_link2_axis/2} ${j2_offset_y/2} 0"
              rpy="0 0 ${atan2(j2_offset_y, arm_link2_axis)}"/>
      <geometry>
        <box size="${arm_link2_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
      <material name="fortis_carbon_fiber"/>
    </visual>
    <!-- J3 motor body (NEMA 17 + Cricket) at the far end of L2, axis along Y. -->
    <visual>
      <origin xyz="${arm_link2_axis} ${j2_offset_y} 0" rpy="0 0 0"/>
      <geometry>
        <box size="${j3_motor_x} ${j3_motor_y} ${j3_motor_z}"/>
      </geometry>
      <material name="fortis_motor_black"/>
    </visual>
    <collision>
      <origin xyz="${arm_link2_axis/2} ${j2_offset_y/2} 0"
              rpy="0 0 ${atan2(j2_offset_y, arm_link2_axis)}"/>
      <geometry>
        <box size="${arm_link2_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
    </collision>
    <!-- CoM at 75% toward J3 along the tube, and biased toward the Y offset
         since the NEMA 17 + Cricket sit at the offset position, not on tube axis. -->
    <xacro:box_inertia m="${arm_link2_mass}"
                       x="${arm_link2_axis}"
                       y="${arm_tube_side}"
                       z="${arm_tube_side}"
                       xyz="${arm_link2_axis*0.75} ${j2_offset_y*0.6} 0"/>
  </link>

  <joint name="joint_j2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 ${j1_to_j2_axis}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j2_lower}" upper="${j2_upper}"
           effort="${j2_effort}" velocity="${j_velocity}"/>
    <dynamics damping="0.8" friction="0.2"/>
  </joint>

  <!-- =================== J3: elbow pitch (revolute about Y) =================== -->
  <link name="link3">
    <!-- Tube spans diagonally from L3 origin (J3 axis) to (arm_link3_axis, j3_offset_y, 0). -->
    <visual>
      <origin xyz="${arm_link3_axis/2} ${j3_offset_y/2} 0"
              rpy="0 0 ${atan2(j3_offset_y, arm_link3_axis)}"/>
      <geometry>
        <box size="${arm_link3_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
      <material name="fortis_carbon_fiber"/>
    </visual>
    <!-- J4 servo (Hitec D845WP) at the far end of L3, axis along Y. -->
    <visual>
      <origin xyz="${arm_link3_axis} ${j3_offset_y} 0" rpy="0 0 0"/>
      <geometry>
        <box size="${j4_motor_x} ${j4_motor_y} ${j4_motor_z}"/>
      </geometry>
      <material name="fortis_motor_black"/>
    </visual>
    <collision>
      <origin xyz="${arm_link3_axis/2} ${j3_offset_y/2} 0"
              rpy="0 0 ${atan2(j3_offset_y, arm_link3_axis)}"/>
      <geometry>
        <box size="${arm_link3_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
    </collision>
    <!-- CoM at 70% toward J4 along the tube, biased toward Y offset where J4
         servo sits (sign matches j3_offset_y -> flipped from j2 side). -->
    <xacro:box_inertia m="${arm_link3_mass}"
                       x="${arm_link3_axis}"
                       y="${arm_tube_side}"
                       z="${arm_tube_side}"
                       xyz="${arm_link3_axis*0.70} ${j3_offset_y*0.6} 0"/>
  </link>

  <joint name="joint_j3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <!-- Y component is the lateral stow offset along J2 rotation axis. -->
    <origin xyz="${arm_link2_axis} ${j2_offset_y} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j3_lower}" upper="${j3_upper}"
           effort="${j3_effort}" velocity="${j_velocity}"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- =================== J4: wrist pitch (revolute about Y) =================== -->
  <link name="link4">
    <visual>
      <origin xyz="${arm_link4_axis/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_link4_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
      <material name="fortis_carbon_fiber"/>
    </visual>
    <collision>
      <origin xyz="${arm_link4_axis/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${arm_link4_tube} ${arm_tube_side} ${arm_tube_side}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${arm_link4_mass}"
                       x="${arm_link4_axis}"
                       y="${arm_tube_side}"
                       z="${arm_tube_side}"
                       xyz="${arm_link4_axis/2} 0 0"/>
  </link>

  <joint name="joint_j4" type="revolute">
    <parent link="link3"/>
    <child  link="link4"/>
    <!-- Zigzag flip: J3 offset is +Y (opposite to J2 which was -Y). -->
    <origin xyz="${arm_link3_axis} ${j3_offset_y} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j4_lower}" upper="${j4_upper}"
           effort="${j4_effort}" velocity="${j_velocity}"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- =================== EE: end effector mount (gripper base) =================== -->
  <!--
    EE attach point is at arm_link4_axis along link4. The gripper_base hangs
    off this attach point by ee_to_gripper. Modeled as a single rigid body.
  -->
  <link name="ee">
    <visual>
      <origin xyz="${ee_to_gripper + gripper_base_x/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_x} ${gripper_base_y} ${gripper_base_z}"/>
      </geometry>
      <material name="fortis_gripper_silver"/>
    </visual>
    <collision>
      <origin xyz="${ee_to_gripper + gripper_base_x/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_x} ${gripper_base_y} ${gripper_base_z}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${gripper_base_mass}"
                       x="${gripper_base_x}"
                       y="${gripper_base_y}"
                       z="${gripper_base_z}"
                       xyz="${ee_to_gripper + gripper_base_x/2} 0 0"/>
  </link>

  <joint name="link4_to_ee" type="fixed">
    <parent link="link4"/>
    <child  link="ee"/>
    <origin xyz="${arm_link4_axis} ${j4_offset_y} 0" rpy="0 0 0"/>
  </joint>

  <!-- =================== gripper jaws =================== -->
  <!--
    Two jaw links. Only the left jaw is driven (prismatic). The right jaw uses
    a <mimic> tag with multiplier -1 so it moves the opposite direction.
    Each jaw origin is at the front face of the gripper base; jaw extends in +X.
  -->
  <xacro:property name="jaw_x_origin" value="${ee_to_gripper + gripper_base_x}"/>

  <link name="jaw_left">
    <visual>
      <origin xyz="${jaw_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${jaw_length} ${jaw_thickness} ${jaw_width}"/>
      </geometry>
      <material name="fortis_jaw_orange"/>
    </visual>
    <collision>
      <origin xyz="${jaw_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${jaw_length} ${jaw_thickness} ${jaw_width}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${jaw_mass}"
                       x="${jaw_length}"
                       y="${jaw_thickness}"
                       z="${jaw_width}"
                       xyz="${jaw_length/2} 0 0"/>
  </link>

  <joint name="joint_gripper" type="prismatic">
    <parent link="ee"/>
    <child  link="jaw_left"/>
    <origin xyz="${jaw_x_origin} 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="${jaw_open_stroke}"
           effort="20.0" velocity="0.05"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <link name="jaw_right">
    <visual>
      <origin xyz="${jaw_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${jaw_length} ${jaw_thickness} ${jaw_width}"/>
      </geometry>
      <material name="fortis_jaw_orange"/>
    </visual>
    <collision>
      <origin xyz="${jaw_length/2} 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${jaw_length} ${jaw_thickness} ${jaw_width}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${jaw_mass}"
                       x="${jaw_length}"
                       y="${jaw_thickness}"
                       z="${jaw_width}"
                       xyz="${jaw_length/2} 0 0"/>
  </link>

  <joint name="joint_gripper_mirror" type="prismatic">
    <parent link="ee"/>
    <child  link="jaw_right"/>
    <origin xyz="${jaw_x_origin} 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${jaw_open_stroke}" upper="0.0"
           effort="20.0" velocity="0.05"/>
    <mimic joint="joint_gripper" multiplier="-1.0" offset="0.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <!-- =================== arm camera (OAK-D Pro AF) =================== -->
  <!--
    Camera body rotated 90 deg about Z so the 97 mm long dimension lies along
    link4's local +Y (transverse to the arm tube, parallel to the gripper
    jaw-opening axis). Lens still points along link4's +X (arm-forward), so
    the optical frame transform downstream is unchanged.
  -->
  <link name="arm_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
      <geometry>
        <box size="${oak_pro_x} ${oak_pro_y} ${oak_pro_z}"/>
      </geometry>
      <material name="fortis_camera_cyan"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
      <geometry>
        <box size="${oak_pro_x} ${oak_pro_y} ${oak_pro_z}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${oak_pro_mass}"
                       x="${oak_pro_x}"
                       y="${oak_pro_y}"
                       z="${oak_pro_z}"
                       rpy="0 0 ${pi/2}"/>
  </link>

  <!--
    Mount on link4, near the EE end, pointing +X (forward along the arm).
    arm_cam_x_offset is measured from the J4 axis (link4 origin).
  -->
  <joint name="link4_to_arm_camera" type="fixed">
    <parent link="link4"/>
    <child  link="arm_camera_link"/>
    <origin xyz="${arm_link4_axis + arm_cam_x_offset} 0 ${arm_cam_z_offset}" rpy="0 0 0"/>
  </joint>

  <!-- Optical frame, ROS convention: Z forward, X right, Y down. -->
  <link name="arm_camera_optical_frame"/>
  <joint name="arm_camera_optical_joint" type="fixed">
    <parent link="arm_camera_link"/>
    <child  link="arm_camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

</robot>
